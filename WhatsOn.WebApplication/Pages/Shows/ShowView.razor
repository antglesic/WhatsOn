@page "/shows/view/{Id:int}"

<PageTitle>@PageTitleText</PageTitle>

@if (_isLoading)
{
	<p><em>Loading show details...</em></p>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
	<div class="alert alert-danger" role="alert">
		@_errorMessage
	</div>
}
else
{
	@if (ShowDetails == null)
	{
		<div class="alert alert-warning" role="alert">
			Movie details not found.
		</div>
	}
	else
	{
		<div class="container py-4">
			<h1>@ShowDetails.Name</h1>

			@if (!string.IsNullOrWhiteSpace(ShowDetails.Tagline))
			{
				<p class="lead text-muted">@ShowDetails.Tagline</p>
			}

			<div class="row g-4">
				<div class="col-lg-4">
					@if (!string.IsNullOrWhiteSpace(ShowDetails?.PosterPath))
					{
						<img class="img-fluid rounded shadow-sm"
							 src="@ShowDetails.PosterPath"
							 alt="@ShowDetails.Name" />
					}
				</div>

				<div class="col-lg-8">
					@if (!string.IsNullOrWhiteSpace(ShowDetails?.BackdropPath))
					{
						<img class="img-fluid rounded mb-3"
							 src="@ShowDetails.BackdropPath"
							 alt="@($"{ShowDetails.Name} backdrop")" />
					}

					<dl class="row">
						<dt class="col-sm-3">First Air Date</dt>
						<dd class="col-sm-9">@DisplayDateOrFallback(ShowDetails?.FirstAirDate)</dd>

						<dt class="col-sm-3">Last Air Date</dt>
						<dd class="col-sm-9">@DisplayDateOrFallback(ShowDetails?.LastAirDate)</dd>

						<dt class="col-sm-3">Seasons</dt>
						<dd class="col-sm-9">@ShowDetails?.NumberOfSeasons</dd>

						<dt class="col-sm-3">Episodes</dt>
						<dd class="col-sm-9">@ShowDetails?.NumberOfEpisodes</dd>

						<dt class="col-sm-3">Status</dt>
						<dd class="col-sm-9">@DisplayOrFallback(ShowDetails?.Status)</dd>

						<dt class="col-sm-3">Rating</dt>
						<dd class="col-sm-9">@ShowDetails?.VoteAverage.ToString("0.0") (@ShowDetails?.VoteCount votes)</dd>

						<dt class="col-sm-3">Genres</dt>
						<dd class="col-sm-9">@ShowDetails?.GenreString</dd>
					</dl>

					@if (!string.IsNullOrWhiteSpace(ShowDetails?.Overview))
					{
						<p>@ShowDetails.Overview</p>
					}
				</div>
			</div>

			<section class="mt-4">
				<h2 class="h4">Trailers</h2>

				@if (ShowDetails?.Trailers == null || ShowDetails.Trailers.Count == 0)
				{
					<p class="text-muted">No trailers available for this movie.</p>
				}
				else
				{
					<div class="row g-3">
						@foreach (var trailer in ShowDetails.Trailers)
						{
							<div class="col-md-6 col-xl-4">
								<div class="card h-100">
									<div class="ratio ratio-16x9">
										<iframe src="@trailer.EmbedUrl"
												title="@trailer.Name"
												loading="lazy"
												allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
												referrerpolicy="strict-origin-when-cross-origin"
												allowfullscreen>
										</iframe>
									</div>
									<div class="card-body">
										<h3 class="h6 card-title mb-1">@trailer.Name</h3>
										<p class="card-text text-muted mb-0">@trailer.Type</p>
									</div>
								</div>
							</div>
						}
					</div>
				}
			</section>
		</div>
	}
}
