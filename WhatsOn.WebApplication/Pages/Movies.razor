@page "/movies"
@using WhatsOn.Web.Services.MovieApiService
@inject IMovieApiClient MovieApiClient

<PageTitle>Movies</PageTitle>

<h1>Movie Search</h1>
<p>Search the WhatsOn API and browse paged movie results from the Blazor WebAssembly client.</p>

<form class="row g-3 mb-4" @onsubmit="HandleSearchAsync" @onsubmit:preventDefault>
	<div class="col-md-8">
		<label class="form-label" for="movie-query">Title</label>
		<input id="movie-query"
			   class="form-control"
			   placeholder="Search for a movie or leave blank to discover titles"
			   @bind="query" />
	</div>
	<div class="col-md-2">
		<label class="form-label" for="include-adult">Include Adult</label>
		<div class="form-check mt-2">
			<input id="include-adult" class="form-check-input" type="checkbox" @bind="includeAdult" />
			<label class="form-check-label" for="include-adult">Yes</label>
		</div>
	</div>
	<div class="col-md-2 d-flex align-items-end">
		<button class="btn btn-primary w-100" type="submit" disabled="@isLoading">
			@(isLoading ? "Searching..." : "Search")
		</button>
	</div>
</form>

@if (isLoading)
{
	<p><em>Loading movies...</em></p>
}
else
{
	@if (!string.IsNullOrWhiteSpace(errorMessage))
	{
		<div class="alert alert-danger" role="alert">@errorMessage</div>
	}
	else if (!string.IsNullOrWhiteSpace(infoMessage))
	{
		<div class="alert alert-secondary" role="status">@infoMessage</div>
	}

	@if (movies.Count > 0)
	{
		<div class="d-flex justify-content-between align-items-center mb-3">
			<p class="mb-0">
				Showing page <strong>@currentPage</strong> of <strong>@totalPages</strong>.
			</p>
			<div class="btn-group" role="group" aria-label="Pagination">
				<button class="btn btn-outline-secondary"
						type="button"
						@onclick="LoadPreviousPageAsync"
						disabled="@(isLoading || currentPage <= 1)">
					Previous
				</button>
				<button class="btn btn-outline-secondary"
						type="button"
						@onclick="LoadNextPageAsync"
						disabled="@(isLoading || currentPage >= totalPages)">
					Next
				</button>
			</div>
		</div>

		<div class="list-group">
			@foreach (Movie movie in movies)
			{
				<article class="list-group-item">
					<h2 class="h5 mb-1">@movie.Title</h2>
					<p class="mb-2">@(!string.IsNullOrWhiteSpace(movie.Overview) ? movie.Overview : "No overview available.")</p>
					<p class="mb-0 text-body-secondary small">
						Release date: @FormatReleaseDate(movie.ReleaseDate)
						<span class="mx-1">|</span>
						Rating: @movie.VoteAverage.ToString("0.0")
					</p>
				</article>
			}
		</div>
	}
}

@code {
	private IReadOnlyList<Movie> movies = [];
	private string query = string.Empty;
	private string errorMessage = string.Empty;
	private string infoMessage = string.Empty;
	private bool includeAdult;
	private bool isLoading;
	private int currentPage = 1;
	private int totalPages = 1;

	protected override Task OnInitializedAsync() => LoadMoviesAsync(1);

	private Task HandleSearchAsync() => LoadMoviesAsync(1);

	private Task LoadPreviousPageAsync() => LoadMoviesAsync(currentPage - 1);

	private Task LoadNextPageAsync() => LoadMoviesAsync(currentPage + 1);

	private async Task LoadMoviesAsync(int pageNumber)
	{
		if (pageNumber < 1)
		{
			return;
		}

		isLoading = true;
		errorMessage = string.Empty;
		infoMessage = string.Empty;

		GetMoviesResponse response = await MovieApiClient.GetMoviesAsync(new GetMoviesRequest
		{
			Query = query.Trim(),
			PageNumber = pageNumber,
			IncludeAdult = includeAdult
		});

		movies = [.. response.Movies.Data];
		currentPage = pageNumber;
		totalPages = Math.Max(response.Movies.TotalPages, 1);

		if (!response.Success)
		{
			errorMessage = response.Message;
		}
		else if (!string.IsNullOrWhiteSpace(response.Message))
		{
			infoMessage = response.Message;
		}
		else if (movies.Count == 0)
		{
			infoMessage = "No movies matched the current search.";
		}

		isLoading = false;
	}

	private static string FormatReleaseDate(string? releaseDate) =>
		string.IsNullOrWhiteSpace(releaseDate) ? "Unknown" : releaseDate;
}
